{
  "name": "operis-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:local": "vite --mode app-local",
    "dev:dev": "vite --mode dev",
    "dev:prod": "vite --mode prod",
    "build:local": "tsc -b && vite build --mode app-local",
    "build:dev": "tsc -b && vite build --mode dev",
    "build:prod": "tsc -b && vite build --mode prod",
    "preview:local": "vite preview --mode app-local",
    "preview:dev": "vite preview --mode dev",
    "preview:prod": "vite preview --mode prod",
    "check:architecture": "node scripts/check-module-boundaries.mjs",
    "perf:bundle-report": "node scripts/report-bundle-sizes.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "antd": "^6.3.2",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "keycloak-js": "^26.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
